{
  "name": "@getsolaris/copse",
  "version": "1.0.2",
  "description": "Git worktree manager with a beautiful TUI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsolaris/copse.git"
  },
  "keywords": [
    "git",
    "worktree",
    "tui",
    "cli",
    "git-worktree"
  ],
  "bin": {
    "copse": "dist/copse.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "latest",
    "@opentui/solid": "latest",
    "solid-js": "latest",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.0.0"
  }
}
