{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "oh-my-worktree config",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "number",
      "const": 1,
      "description": "Config schema version"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "worktreeDir": {
          "type": "string",
          "default": "~/.omw/worktrees/{repo}-{branch}",
          "description": "Directory pattern. Supports ~ (home), {repo} and {branch} variables."
        },
        "copyFiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "linkFiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "postCreate": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "postRemove": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "autoUpstream": {
          "type": "boolean",
          "default": true
        },
        "sharedDeps": {
          "$ref": "#/definitions/sharedDeps"
        }
      }
    },
    "theme": {
      "type": "string"
    },
    "sessions": {
      "type": "object",
      "additionalProperties": false,
      "description": "Tmux session management for worktrees",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable tmux session integration"
        },
        "autoCreate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create tmux session on worktree creation"
        },
        "autoKill": {
          "type": "boolean",
          "default": false,
          "description": "Automatically kill tmux session on worktree removal"
        },
        "prefix": {
          "type": "string",
          "default": "omw",
          "description": "Prefix for tmux session names"
        },
        "defaultLayout": {
          "type": "string",
          "description": "Default layout name to use when creating sessions"
        },
        "layouts": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["windows"],
            "additionalProperties": false,
            "properties": {
              "windows": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Window name"
                    },
                    "command": {
                      "type": "string",
                      "description": "Command to run in the window"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "worktreeDir": { "type": "string" },
          "copyFiles": { "type": "array", "items": { "type": "string" } },
          "linkFiles": { "type": "array", "items": { "type": "string" } },
          "postCreate": { "type": "array", "items": { "type": "string" } },
          "postRemove": { "type": "array", "items": { "type": "string" } },
          "autoUpstream": { "type": "boolean" },
          "sharedDeps": { "$ref": "#/definitions/sharedDeps" },
          "monorepo": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "autoDetect": {
                "type": "boolean",
                "default": true,
                "description": "Automatically detect monorepo tools (pnpm, turbo, nx, lerna, npm workspaces)"
              },
              "extraPatterns": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Additional glob patterns to discover packages not caught by auto-detection"
              },
              "hooks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["glob"],
                  "additionalProperties": false,
                  "properties": {
                    "glob": {
                      "type": "string",
                      "description": "Glob pattern to match focus paths"
                    },
                    "copyFiles": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Files to copy from main repo's package path to worktree's package path"
                    },
                    "linkFiles": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Files/dirs to symlink from main repo's package path to worktree's package path"
                    },
                    "postCreate": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "postRemove": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "worktreeDir": { "type": "string" },
          "copyFiles": { "type": "array", "items": { "type": "string" } },
          "linkFiles": { "type": "array", "items": { "type": "string" } },
          "postCreate": { "type": "array", "items": { "type": "string" } },
          "postRemove": { "type": "array", "items": { "type": "string" } },
          "autoUpstream": { "type": "boolean" },
          "base": { "type": "string" }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoCleanMerged": { "type": "boolean" },
        "staleAfterDays": { "type": "number", "minimum": 1 },
        "maxWorktrees": { "type": "number", "minimum": 1 }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "defaults": { "$ref": "#/properties/defaults" },
          "repos": { "$ref": "#/properties/repos" },
          "theme": { "type": "string" },
          "templates": { "$ref": "#/properties/templates" },
          "lifecycle": { "$ref": "#/properties/lifecycle" },
          "sessions": { "$ref": "#/properties/sessions" }
        }
      }
    },
    "activeProfile": {
      "type": "string"
    }
  },
  "definitions": {
    "sharedDeps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["hardlink", "symlink", "copy"]
        },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "invalidateOn": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
